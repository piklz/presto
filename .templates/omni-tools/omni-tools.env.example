IMMICH_API_KEY=API KEY HERE 
#(use your immich server settings to make one )
IMMICH_URL=http://immich_server:2283
EXTERNAL_IMMICH_URL=http://${SYSTEM_HOSTNAME}:2283

DB_HOST=database
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE_NAME=immich

TZ=Europe/London

# Optional - AI Configuration for Smart Search (Find)
AI_API_KEY=your_api_key_here 
# API key for your OpenAI-compatible provider
AI_BASE_URL="https://api.openai.com/v1" 
# e.g. https://api.openai.com/v1 (OpenAI), https://api.groq.com/openai/v1 (Groq), http://host.docker.internal:11434/v1 (Ollama)
AI_MODEL="gpt-4o-mini" 
# e.g. gpt-4o-mini, llama-3.1-8b-instant, llama3.1